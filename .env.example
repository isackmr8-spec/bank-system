# Backend Environment Variables for Production Hosting

# JWT Secret (change for prod)
JWT_SECRET=your-super-secret-jwt-key-change-this-32chars-min

# Database (Render/Heroku provides DATABASE_URL)
# DATABASE_URL=postgresql://user:pass@host:port/db

# OpenAI for AI Chat (optional - fallback works without)
OPENAI_API_KEY=sk-proj-...

# Email SMTP (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-password

# Server Port (hosting platform sets)
PORT=10000

# Copy to .env and fill values!

